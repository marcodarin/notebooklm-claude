NODE_ENV=production
PORT=10000
LOG_LEVEL=info

# Token for authenticating Claude connector -> MCP server
# Leave empty to disable auth (development only)
MCP_AUTH_TOKEN=changeme

# NotebookLM authentication
# Option 1: Inline JSON (recommended for Render/CI)
# Paste your Playwright storage_state.json content here
# NOTEBOOKLM_AUTH_JSON={"cookies":[...]}

# Option 2: File-based (for local development)
# Place storage_state.json at this path
SESSION_STORE_PATH=/tmp/notebooklm-session

# NotebookLM adapter settings
GOOGLE_SERVICE_ACCOUNT_MODE=browser
HEADLESS=true
NOTEBOOKLM_DEFAULT_NOTEBOOK_URL=

# Optional: Override the build label for NotebookLM API
# NOTEBOOKLM_BL=boq_labs-tailwind-frontend_20251221.14_p0
